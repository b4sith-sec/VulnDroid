<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="OTP Verification" android:textSize="26sp" android:textStyle="bold"
            android:textColor="#FFFFFF" android:layout_marginTop="32dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VULN-OTP-01 - No rate limiting on OTP verification"
            android:textSize="11sp" android:textColor="#888888" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="A 4-digit OTP has been sent (logged to logcat). The verify action below has no rate limiting, no lockout, and no exponential backoff - all 10000 combinations can be brute-forced."
            android:textSize="12sp" android:textColor="#AAAAAA"
            android:background="#0A0A0A" android:padding="14dp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ENTER OTP" android:textSize="10sp"
            android:textColor="#888888" android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_otp_input"
            android:layout_width="match_parent" android:layout_height="64dp"
            android:hint="0000" android:textColorHint="#444444"
            android:textColor="#FFFFFF" android:textSize="24sp"
            android:background="#111111" android:padding="14dp"
            android:singleLine="true" android:inputType="number"
            android:maxLength="4" android:gravity="center"
            android:fontFamily="monospace" android:letterSpacing="0.5"/>

        <Button android:id="@+id/btn_verify_otp"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Verify OTP" android:backgroundTint="#FFFFFF"
            android:textColor="#000000" android:textSize="14sp"
            android:layout_marginTop="20dp"/>

        <TextView android:id="@+id/tv_attempt_count"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Attempts: 0 (no limit, no lockout)"
            android:textSize="11sp" android:textColor="#555555" android:fontFamily="monospace"
            android:layout_marginTop="12dp" android:gravity="center"/>

        <TextView android:id="@+id/tv_otp_result"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="12sp" android:fontFamily="monospace"
            android:padding="14dp" android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="16dp" android:visibility="gone"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Hint: run adb logcat | grep Gu3ssWeak_OTP to see the OTP, or write a script to brute-force 0000-9999."
            android:textSize="11sp" android:textColor="#555555" android:fontFamily="monospace"
            android:background="#0A0A0A" android:padding="14dp"
            android:lineSpacingMultiplier="1.5" android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>
