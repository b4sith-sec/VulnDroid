<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Gu3ssWeak" android:textSize="32sp" android:textStyle="bold"
            android:textColor="#FFFFFF" android:layout_gravity="center"
            android:paddingTop="24dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Vulnerable Android Lab" android:textSize="13sp"
            android:textColor="#FFFFFF" android:layout_gravity="center" android:layout_marginTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="19 Vulnerabilities · OWASP Mobile Top 10"
            android:textSize="11sp" android:textColor="#FFFFFF"
            android:layout_gravity="center" android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="For authorized security research only"
            android:background="#111111" android:textColor="#FFFFFF"
            android:textSize="11sp" android:gravity="center"
            android:padding="10dp" android:layout_marginBottom="20dp"/>

        <!-- WEBVIEW -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WEBVIEW LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_webview" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="WV-01 · JS Enabled No Origin Check"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_webview2" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="WV-02 · JavascriptInterface Bridge"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_webview3" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="WV-03 · Local File Read via file://"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_webview4" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="WV-04 · Arbitrary URL From Intent"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="16dp"/>

        <!-- DEEPLINK -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DEEPLINK LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_deeplink" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="DL-01/02 · Deeplink Hijack"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_deeplink2" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="DL-03 · Token Overwrite via Deeplink"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_deeplink_chain" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="DL-CHAIN · Deeplink to WebView RCE"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="16dp"/>

        <!-- AUTH / SQL -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AUTH / SQL INJECTION LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_login" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="SQL-01 · Login SQL Injection Bypass"
            android:backgroundTint="#FFFFFF" android:textColor="#000000" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_admin" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="AP-01/02/03 · Admin Panel Direct Access"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="16dp"/>

        <!-- BROADCAST -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BROADCAST RECEIVER LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_broadcast" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="BR-01/02 · Token Injection via Broadcast"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_broadcast2" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="BR-03 · Sensitive Data in Logcat"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="16dp"/>

        <!-- SERVICE -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SERVICE LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_service_wipe" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="SV-02a · Data Wipe via Service"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn_service_exfil" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="SV-02b · Data Exfil SSRF via Service"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="NETWORK INTERCEPTION LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_network" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="NET-01 - Cleartext Traffic, No Cert Pinning"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BANKING / OTP LABS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_otp" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="OTP-01 - OTP Brute Force, No Rate Limit"
            android:backgroundTint="#111111" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginBottom="20dp"/>

        <!-- ADB -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ADB QUICK COMMANDS" android:textSize="11sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="$ adb shell am broadcast -a com.vulndroid.app.SEND_TOKEN --es token FAKE&#10;$ adb shell am start -n com.vulndroid.app/.activities.AdminPanelActivity&#10;$ adb logcat | grep Gu3ssWeak_FLAG"
            android:background="#111111" android:textColor="#FFFFFF"
            android:fontFamily="monospace" android:textSize="10sp"
            android:padding="12dp" android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/btn_submit_flag" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Submit Flag"
            android:backgroundTint="#FFFFFF" android:textColor="#000000"
            android:textSize="14sp" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_scoreboard" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="CTF Scoreboard"
            android:backgroundTint="#111111" android:textColor="#FFFFFF"
            android:textSize="14sp" android:layout_marginBottom="32dp"/>
    </LinearLayout>
</ScrollView>
