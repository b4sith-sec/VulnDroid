<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Payment Details" android:textSize="26sp" android:textStyle="bold"
            android:textColor="#FFFFFF" android:layout_marginTop="32dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VULN-BR-03 - Sensitive payment data written to logcat"
            android:textSize="11sp" android:textColor="#888888" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="This payment form logs card number, expiry, and CVV in plaintext to logcat on every keystroke and on submit. Any app with READ_LOGS permission, or adb logcat, can capture full card details."
            android:textSize="12sp" android:textColor="#AAAAAA"
            android:background="#0A0A0A" android:padding="14dp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CARD NUMBER" android:textSize="10sp"
            android:textColor="#888888" android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_card_number"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="4111 1111 1111 1111" android:textColorHint="#444444"
            android:textColor="#FFFFFF" android:textSize="14sp"
            android:background="#111111" android:padding="14dp"
            android:singleLine="true" android:inputType="number"
            android:fontFamily="monospace"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="EXPIRY" android:textSize="10sp"
                    android:textColor="#888888" android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_card_expiry"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="MM/YY" android:textColorHint="#444444"
                    android:textColor="#FFFFFF" android:textSize="14sp"
                    android:background="#111111" android:padding="14dp"
                    android:singleLine="true" android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CVV" android:textSize="10sp"
                    android:textColor="#888888" android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_card_cvv"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="123" android:textColorHint="#444444"
                    android:textColor="#FFFFFF" android:textSize="14sp"
                    android:background="#111111" android:padding="14dp"
                    android:singleLine="true" android:inputType="numberPassword"
                    android:fontFamily="monospace"/>
            </LinearLayout>

        </LinearLayout>

        <Button android:id="@+id/btn_pay"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Pay Now" android:backgroundTint="#FFFFFF"
            android:textColor="#000000" android:textSize="14sp"
            android:layout_marginTop="24dp"/>

        <TextView android:id="@+id/tv_log_hint"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="#30D158" android:fontFamily="monospace"
            android:background="#0A0A0A" android:padding="14dp"
            android:lineSpacingMultiplier="1.5" android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
